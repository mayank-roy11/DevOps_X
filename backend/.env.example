APP_NAME=Feedback Service
ENVIRONMENT=development
DEBUG=true

# Option A: provide your own DATABASE_URL.
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/feedback_db

# Option B: set individual DB fields.
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=db

# Allow the React dev server to call the API (Vite defaults to 5173).
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

